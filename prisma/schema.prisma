generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Study {
  id               Int      @id @default(autoincrement())
  nctId            String   @unique
  title            String
  summary          String   @default("")
  status           String   @default("")
  studyType        String   @default("")
  phase            String   @default("")
  conditions       String   @default("")
  interventions    String   @default("")
  sponsor          String   @default("")
  eligibility      String   @default("")
  gender           String   @default("")
  minimumAge       String   @default("")
  maximumAge       String   @default("")
  healthyVolunteers String  @default("")
  city             String   @default("")
  state            String   @default("")
  zip              String   @default("")
  country          String   @default("")
  lastUpdated      String   @default("")
  url              String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  categories StudyCategory[]
  locations  StudyLocation[]
}

model StudyLocation {
  id        Int    @id @default(autoincrement())
  studyId   Int
  facility  String @default("")
  city      String @default("")
  state     String @default("")
  zip       String @default("")
  country   String @default("")

  study Study @relation(fields: [studyId], references: [id], onDelete: Cascade)
}

model StudyCategory {
  studyId    Int
  categoryId Int

  study    Study    @relation(fields: [studyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([studyId, categoryId])
}

model Company {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model State {
  id   Int    @id @default(autoincrement())
  name String @unique
  abbr String @default("")
  slug String @unique

  cities City[]
}

model City {
  id      Int    @id @default(autoincrement())
  name    String
  stateId Int
  slug    String

  state State @relation(fields: [stateId], references: [id])

  @@unique([name, stateId])
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique
  slug String @unique

  studies StudyCategory[]
}

model StudyType {
  id   Int    @id @default(autoincrement())
  name String @unique
}
